# Database
DATABASE_URL=postgresql+asyncpg://tradecraft:tradecraft@localhost:5432/tradecraft
POSTGRES_USER=tradecraft
POSTGRES_PASSWORD=tradecraft
POSTGRES_DB=tradecraft

# Redis
REDIS_URL=redis://localhost:6379/0

# Security
SECRET_KEY=your-super-secret-key-change-this-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# Environment
ENVIRONMENT=development

# Frontend
NEXT_PUBLIC_API_URL=http://localhost:8000
NEXT_PUBLIC_TRADE_API_URL=http://localhost:3001

# Broker (for future sprints)
ZERODHA_API_KEY=
ZERODHA_API_SECRET=
ZERODHA_REDIRECT_URL=

# Alerts (for future sprints)
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# MiroFish sidecar integration (advisory-only)
MIROFISH_ENABLED=false
# Local dev (backend on host): http://localhost:5001
# Backend in Docker hitting host-side MiroFish on Windows/Mac: http://host.docker.internal:5001
# Backend in Docker with MiroFish service in same compose network: http://mirofish:5001
MIROFISH_BASE_URL=http://localhost:5001
MIROFISH_API_PREFIX=/api
MIROFISH_TIMEOUT_SECONDS=30
MIROFISH_FAIL_OPEN=true
MIROFISH_API_KEY=
MIROFISH_SIMULATION_ID=
MIROFISH_SYMBOL_SIMULATION_MAP=
